{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio Config",
  "description": "Per-repo portfolio metadata. Place at repo root as portfolio.json.",
  "type": "object",
  "required": [
    "title",
    "tagline",
    "description",
    "category",
    "status",
    "techStack",
    "isPublic",
    "startDate"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to this schema file for IDE autocomplete"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-friendly identifier. Derived from directory name if omitted."
    },
    "title": {
      "type": "string"
    },
    "tagline": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["featured", "games", "professional", "tools"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "maintained", "archived"]
    },
    "techStack": {
      "type": "array",
      "items": { "type": "string" }
    },
    "liveUrl": {
      "type": "string"
    },
    "repoUrl": {
      "type": "string"
    },
    "roadmapUrl": {
      "type": "string"
    },
    "images": {
      "type": "object",
      "properties": {
        "thumbnail": {
          "type": "string",
          "description": "Override thumbnail path. Defaults to /images/projects/{slug}-thumb.png"
        },
        "screenshots": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "businessContext": {
      "type": "string"
    },
    "isPublic": {
      "type": "boolean"
    },
    "startDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "YYYY-MM format"
    },
    "featured": {
      "type": "boolean"
    },
    "hasCaseStudy": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
